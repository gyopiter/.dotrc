#!/usr/bin/env bash

set -euo pipefail

DOTRC_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
EMACS_CONFIG="$DOTRC_DIR/emacs"
EMACS_INIT="$HOME/.emacs"
BEGIN_MARKER=';; >>> .dotrc Emacs setup >>>'
END_MARKER=';; <<< .dotrc Emacs setup <<<'

if [ ! -f "$EMACS_CONFIG" ]; then
  echo "Emacs configuration not found: $EMACS_CONFIG" >&2
  exit 1
fi

if [ -e "$EMACS_INIT" ] && [ ! -f "$EMACS_INIT" ]; then
  echo "Cannot configure $EMACS_INIT: it is not a regular file" >&2
  exit 1
fi

if grep -qF "$BEGIN_MARKER" "$EMACS_INIT" 2>/dev/null; then
  if grep -qF "$END_MARKER" "$EMACS_INIT"; then
    echo "Emacs configuration already loaded in $EMACS_INIT"
    exit 0
  fi

  echo "Incomplete .dotrc Emacs setup block in $EMACS_INIT" >&2
  echo "Remove the incomplete block manually, then run this script again." >&2
  exit 1
fi

# Escape the path for use in an Emacs Lisp string.
ESCAPED_CONFIG="$(printf '%s' "$EMACS_CONFIG" | sed 's/[\\"]/\\&/g')"

if [ -f "$EMACS_INIT" ]; then
  printf '\n%s\n(load "%s" nil nil)\n%s\n' \
    "$BEGIN_MARKER" "$ESCAPED_CONFIG" "$END_MARKER" >> "$EMACS_INIT"
else
  printf '%s\n(load "%s" nil nil)\n%s\n' \
    "$BEGIN_MARKER" "$ESCAPED_CONFIG" "$END_MARKER" > "$EMACS_INIT"
fi

echo "Loaded $EMACS_CONFIG from $EMACS_INIT"
