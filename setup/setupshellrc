#!/usr/bin/env bash

# Shell setup
# ===========
#
# Install fzf and the shell plugins used by this repository, then configure
# Bash or Zsh to load ~/.dotrc/shellrc.
#
# Usage:
#   bash setup/setupshellrc bash
#   bash setup/setupshellrc zsh
#
# The script is safe to run repeatedly. It preserves configuration outside
# the .dotrc marker block and upgrades an existing unmarked source line.

set -euo pipefail

SHELLRC_SOURCE='source ~/.dotrc/shellrc'
BASHRC_INIT="$HOME/.bashrc"
ZSHRC_INIT="$HOME/.zshrc"
BASHRC_BEGIN_MARKER='# >>> .dotrc shellrc setup >>>'
BASHRC_END_MARKER='# <<< .dotrc shellrc setup <<<'
ZSHRC_BEGIN_MARKER='# >>> .dotrc shellrc setup >>>'
ZSHRC_END_MARKER='# <<< .dotrc shellrc setup <<<'

usage() {
  cat <<'EOF'
Usage:
  bash setup/setupshellrc bash
  bash setup/setupshellrc zsh

Install shell tools and configure exactly one shell target.
EOF
}

validate_shellrc_block() {
  local init_file="$1"
  local begin_marker="$2"
  local end_marker="$3"

  if [ -L "$init_file" ]; then
    echo "Cannot configure $init_file: symlinks are not supported" >&2
    exit 1
  fi

  if [ -e "$init_file" ] && [ ! -f "$init_file" ]; then
    echo "Cannot configure $init_file: it is not a regular file" >&2
    exit 1
  fi

  [ -e "$init_file" ] || return 0

  if ! awk -v begin="$begin_marker" -v end="$end_marker" '
    $0 == begin {
      if (in_block) { malformed = 1 }
      in_block = 1
      next
    }
    $0 == end {
      if (!in_block) { malformed = 1 }
      in_block = 0
      next
    }
    END {
      if (in_block) { malformed = 1 }
      exit malformed
    }
  ' "$init_file"; then
    echo "Incomplete or malformed .dotrc shellrc setup block in $init_file" >&2
    echo "Repair the block manually, then run this script again." >&2
    exit 1
  fi
}

marker_block_exists() {
  local init_file="$1"
  local begin_marker="$2"
  local end_marker="$3"

  awk -v begin="$begin_marker" -v end="$end_marker" '
    $0 == begin { in_block = 1; next }
    in_block && $0 == end { found = 1; in_block = 0; next }
    END { exit(found ? 0 : 1) }
  ' "$init_file"
}

configure_shellrc() {
  local init_file="$1"
  local begin_marker="$2"
  local end_marker="$3"
  local tmp_init
  local original_mode=""

  validate_shellrc_block "$init_file" "$begin_marker" "$end_marker"

  if [ -e "$init_file" ] && marker_block_exists "$init_file" "$begin_marker" "$end_marker"; then
    echo "shellrc already configured in $init_file"
    return 0
  fi

  if [ -f "$init_file" ]; then
    if original_mode="$(stat -f '%Lp' "$init_file" 2>/dev/null)" || \
      original_mode="$(stat -c '%a' "$init_file" 2>/dev/null)"; then
      :
    else
      echo "Cannot determine permissions for $init_file" >&2
      exit 1
    fi
  fi

  touch "$init_file"

  tmp_init="$(mktemp "${init_file}.tmp.XXXXXX")"
  trap 'rm -f -- "$tmp_init"' RETURN

  awk \
    -v begin="$begin_marker" \
    -v end="$end_marker" \
    -v source="$SHELLRC_SOURCE" '
    $0 == begin { in_block = 1; next }
    in_block && $0 == end { in_block = 0; next }
    !in_block && $0 == source && !wrapped {
      print begin
      print source
      print end
      wrapped = 1
      next
    }
    !in_block { print }
    END {
      if (!wrapped) {
        if (NR > 0) { print "" }
        print begin
        print source
        print end
      }
    }
  ' "$init_file" > "$tmp_init"

  if [ -n "$original_mode" ]; then
    chmod "$original_mode" "$tmp_init"
  fi
  mv -f -- "$tmp_init" "$init_file"
  trap - RETURN
  echo "Configured shellrc in $init_file"
}

install_fzf() {
  if command -v fzf >/dev/null 2>&1; then
    echo "fzf already installed"
  elif command -v brew >/dev/null 2>&1; then
    brew install fzf
  else
    if [ -d ~/.fzf ]; then
      echo "fzf repository already installed"
    else
      git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf
    fi

    ~/.fzf/install --bin --no-update-rc
  fi
}

install_ohmyzsh() {
  if [ -d ~/.oh-my-zsh ]; then
    echo "Oh My Zsh already installed"
  else
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
  fi

  if [ -d ~/.oh-my-zsh ]; then
    zsh_custom_dir="${ZSH_CUSTOM:-${ZSH:-$HOME/.oh-my-zsh}/custom}"
    mkdir -p "$zsh_custom_dir/plugins"

    if [ -d "$zsh_custom_dir/plugins/zsh-completions" ]; then
      echo "zsh-completions already installed"
    else
      git clone https://github.com/zsh-users/zsh-completions "$zsh_custom_dir/plugins/zsh-completions"
    fi

    if [ -d "$zsh_custom_dir/plugins/fzf-tab" ]; then
      echo "fzf-tab already installed"
    else
      git clone https://github.com/Aloxaf/fzf-tab "$zsh_custom_dir/plugins/fzf-tab"
    fi

    if [ -d "$zsh_custom_dir/plugins/zsh-autosuggestions" ]; then
      echo "zsh-autosuggestions already installed"
    else
      git clone https://github.com/zsh-users/zsh-autosuggestions "$zsh_custom_dir/plugins/zsh-autosuggestions"
    fi

    if [ -d "$zsh_custom_dir/plugins/zsh-syntax-highlighting" ]; then
      echo "zsh-syntax-highlighting already installed"
    else
      git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$zsh_custom_dir/plugins/zsh-syntax-highlighting"
    fi
  fi

  configure_shellrc "$ZSHRC_INIT" "$ZSHRC_BEGIN_MARKER" "$ZSHRC_END_MARKER"
}

install_ohmybash() {
  if [ -d ~/.oh-my-bash ]; then
    echo "Oh My Bash already installed"
  else
    bash -c "$(curl -fsSL https://raw.githubusercontent.com/ohmybash/oh-my-bash/master/tools/install.sh)"
  fi

  configure_shellrc "$BASHRC_INIT" "$BASHRC_BEGIN_MARKER" "$BASHRC_END_MARKER"
}

main() {
  if [ "$#" -ne 1 ]; then
    if [ "$#" -eq 0 ]; then
      echo "Missing shell target." >&2
    else
      echo "Expected exactly one shell target." >&2
    fi
    usage >&2
    exit 1
  fi

  case "$1" in
    bash)
      validate_shellrc_block "$BASHRC_INIT" "$BASHRC_BEGIN_MARKER" "$BASHRC_END_MARKER"
      install_fzf
      install_ohmybash
      ;;
    zsh)
      validate_shellrc_block "$ZSHRC_INIT" "$ZSHRC_BEGIN_MARKER" "$ZSHRC_END_MARKER"
      install_fzf
      install_ohmyzsh
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "Unknown shell target: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
